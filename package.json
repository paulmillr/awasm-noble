{
  "name": "@awasm/noble",
  "version": "0.1.0",
  "description": "Auditable WASM implementation of cryptographic hashes & ciphers",
  "files": [
    "src",
    "modules",
    "targets",
    "*.js",
    "*.js.map",
    "*.d.ts",
    "*.d.ts.map"
  ],
  "devDependencies": {
    "@awasm/compiler": "0.1.0",
    "@noble/ciphers": "~2.2.0",
    "@noble/hashes": "~2.2.0",
    "@paulmillr/jsbt": "0.5.0",
    "@scure/base": "2.0.0",
    "fast-check": "4.5.3",
    "prettier": "3.6.2",
    "typescript": "5.9.2"
  },
  "scripts": {
    "bench": "node benchmark/1-hashes-ciphers.ts; node benchmark/2-parallel.ts",
    "build": "npm run build:targets && tsc && npm run format",
    "build:targets": "node scripts/build-targets.ts",
    "build:clean": "rm -rf src/targets targets modules *.js *.js.map *.d.ts *.d.ts.map 2> /dev/null",
    "format": "prettier --write --no-error-on-unmatched-pattern '*.js' '*.d.ts' 'src/**/*.{js,ts}' 'modules/**/*.{js,ts}' 'targets/**/*.{js,ts}' 'test/*.ts' 'test/ciphers/*.ts' 'test/hashes/*.ts'",
    "test": "node test/index.ts",
    "test:zeroize": "CHECK_ZEROIZE=1 node test/index.ts"
  },
  "exports": {
    ".": {
      "types": "./targets/wasm/index.d.ts",
      "default": "./targets/wasm/index.js"
    },
    "./js.js": "./targets/js/index.js",
    "./wasm_threads.js": "./targets/wasm_threads/index.js",
    "./runtime.js": "./targets/runtime/index.js",
    "./stub.js": "./targets/stub/index.js",
    "./kdf.js": "./kdf.js",
    "./hmac.js": "./hmac.js",
    "./hkdf.js": "./hkdf.js",
    "./workers.js": "./workers.js",
    "./utils.js": "./utils.js",
    "./webcrypto.js": "./webcrypto.js"
  },
  "engines": {
    "node": ">= 22.22.0"
  },
  "keywords": [
    "wasm",
    "sha",
    "sha2",
    "sha3",
    "blake",
    "blake3",
    "pbkdf2",
    "scrypt",
    "sha256",
    "salsa20",
    "chacha",
    "aes",
    "keccak",
    "kdf",
    "hash",
    "cryptography",
    "security",
    "noble"
  ],
  "homepage": "https://paulmillr.com/awasm/",
  "funding": "https://paulmillr.com/funding/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulmillr/awasm-noble.git"
  },
  "type": "module",
  "main": "./targets/wasm/index.js",
  "module": "./targets/wasm/index.js",
  "types": "./targets/wasm/index.d.ts",
  "sideEffects": false,
  "author": "Paul Miller (https://paulmillr.com)",
  "license": "MIT"
}
